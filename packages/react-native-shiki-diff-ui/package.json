{
  "name": "react-native-shiki-diff-ui",
  "version": "0.1.0",
  "description": "Line numbers and stacked file diffs for React Native with Shiki tokens",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "import": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    }
  },
  "main": "lib/module/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && eslint .",
    "lint:fix": "oxlint . --fix && eslint . --fix"
  },
  "peerDependencies": {
    "@shikijs/core": "^3.0.0",
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "diff": "catalog:diff"
  },
  "devDependencies": {
    "@babel/core": "catalog:babel",
    "@shikijs/core": "catalog:shiki",
    "@types/react": "catalog:types",
    "del-cli": "catalog:build",
    "react": "catalog:react",
    "react-native": "0.82.1",
    "react-native-builder-bob": "catalog:build",
    "typescript": "catalog:types"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
